# Get this from Discord Developer Portal > Your Bot > Bot > Token
DISCORD_TOKEN=your_bot_token_here

# Comma-separated list of role IDs that can use the /reply command
# Get role IDs: Enable Developer Mode in Discord, right-click a role, Copy ID
ALLOWED_ROLE_IDS=123456789012345678,987654321098765432

# Role ID to assign when a member is live on Twitch/Kick/YouTube and their
# stream metadata contains STREAM_KEYWORD. Leave empty to disable.
# The bot's role must be ABOVE this role and have "Manage Roles" permission.
# Requires "Server Members Intent" and "Presence Intent" enabled in the
# Discord Developer Portal.
LIVE_ROLE_ID=

# Keyword that must appear in the stream title/details (case-insensitive).
STREAM_KEYWORD=RosalitaRP
